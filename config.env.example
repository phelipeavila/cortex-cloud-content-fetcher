# =============================================================================
# Cortex Cloud Compliance Fetcher - Configuration
# =============================================================================
# Copy this file to config.env and fill in your values.
# DO NOT commit config.env to version control!

# -----------------------------------------------------------------------------
# API CREDENTIALS (Required)
# -----------------------------------------------------------------------------
# Your Cortex Cloud API URL (without trailing slash)
# Example: https://api-mycompany.xdr.us.paloaltonetworks.com
API_URL=https://api-YOUR_TENANT.xdr.us.paloaltonetworks.com

# API Key ID (x-xdr-auth-id header)
# Found in: Settings > Configurations > API Keys
API_ID=1

# API Key (Authorization header)
# The full API key string
API_KEY=YOUR_API_KEY_HERE

# -----------------------------------------------------------------------------
# HTTP COLLECTOR CONFIGURATION (Optional - for pushing data)
# -----------------------------------------------------------------------------
# Tenant URL used to build the collector endpoint
# Format: yourfqdn.xdr.us.paloaltonetworks.com (without https://api-)
# The collector URL will be: https://api-{TENANT_EXTERNAL_URL}/logs/v1/event
TENANT_EXTERNAL_URL=YOUR_TENANT.xdr.us.paloaltonetworks.com

# API Key for pushing COMPLIANCE ASSETS data (used by assets push)
COMPLIANCE_API_KEY=

# API Key for pushing CONTROL SUMMARIES data (used by summary push)
CONTROLS_API_KEY=

# -----------------------------------------------------------------------------
# ASSESSMENTS CONFIGURATION (Required)
# -----------------------------------------------------------------------------
# JSON array defining which standards and profiles to fetch.
# Format: [{"standard": "Standard Name", "profiles": ["Profile1", "Profile2"]}]
#
# Example with multiple standards:
# ASSESSMENTS=[{"standard": "CIS Azure Kubernetes Service (AKS) Benchmark v1.5", "profiles": ["CIS Azure Kubernetes Service (AKS) Benchmark v1.5"]}, {"standard": "CIS Critical Security Controls v8.1", "profiles": ["CIS Critical Security Controls v8.1"]}]
#
# Example with single standard:
ASSESSMENTS=[{"standard": "CIS Azure Kubernetes Service (AKS) Benchmark v1.5", "profiles": ["CIS Azure Kubernetes Service (AKS) Benchmark v1.5"]}]

# -----------------------------------------------------------------------------
# PROCESSING OPTIONS
# -----------------------------------------------------------------------------
# Page size for asset pagination (max: 100)
PAGE_SIZE=100

# Batch size for HTTP Collector push (default: 500)
BATCH_SIZE=500

# Maximum number of anchors to process (0 = all)
MAX_ANCHORS=0

# Number of parallel workers for API requests (default: 5)
# Used for both control fetching AND asset fetching.
# Increase for faster fetching, decrease if hitting rate limits.
PARALLEL_WORKERS=5

# Pre-flight ETA tuning: average seconds per parallel API wave
# (one wave = up to PARALLEL_WORKERS page calls for a single anchor).
# Increase if ETA is too optimistic, decrease if ETA is too pessimistic.
# How to calculate from a real run:
#   1) For each anchor: waves = ceil(pages / PARALLEL_WORKERS)
#   2) total_waves = sum(waves across anchors)
#   3) EST_API_WAVE_SECONDS = elapsed_seconds / total_waves
EST_API_WAVE_SECONDS=7.0

# Dry run mode - if true, won't push to HTTP Collector
DRY_RUN=true

# -----------------------------------------------------------------------------
# DEDUP OPTIONS
# -----------------------------------------------------------------------------
# When enabled, the script queries Cortex datasets to avoid re-pushing the same
# (assessment_profile_revision, calendar day in DEDUP_TIMEZONE) pair. The same
# revision pushed multiple times within the same calendar day is treated as a
# duplicate; the same revision on a different calendar day is treated as new
# and will be pushed.
# Use --force-push on the CLI to bypass dedup for a single run.
DEDUP_ENABLED=true

# How far back to look in the destination datasets when checking for existing
# revisions (in days).
DEDUP_TIMEFRAME_DAYS=30

# Destination dataset names (override only if your collectors write elsewhere).
ASSETS_DATASET_NAME=panw_compliance_assets_raw
SUMMARY_DATASET_NAME=panw_compliance_summary_raw

# Timezone used to define the "day" boundary for dedup. Both sides (script and
# XQL filter) use this timezone. Any IANA timezone name. Default: UTC.
# Examples: UTC, America/New_York, America/Sao_Paulo, Europe/London
DEDUP_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# OUTPUT OPTIONS
# -----------------------------------------------------------------------------
# Directory for output files (default: ./output)
OUTPUT_DIR=./output

# -----------------------------------------------------------------------------
# DEBUG / TROUBLESHOOTING (Optional - leave commented for normal use)
# -----------------------------------------------------------------------------
# Dump every /compliance/get_assets payload to terminal and (optionally) file.
# DUMP_GET_ASSETS_PAYLOAD=true
# DUMP_GET_ASSETS_PAYLOAD_FILE=./output/get_assets_payloads.ndjson
# DUMP_GET_ASSETS_CURL=true

# Dump dedup XQL API requests/responses (/xql/start_xql_query and
# /xql/get_query_results). Useful when troubleshooting why anchors are or are
# not being deduped. WARNING: when DUMP_DEDUP_XQL_CURL=true the printed curl
# command includes auth headers - treat the logs as sensitive.
# DUMP_DEDUP_XQL_REQUESTS=true
# DUMP_DEDUP_XQL_REQUESTS_FILE=./output/dedup_xql_requests.ndjson
# DUMP_DEDUP_XQL_CURL=true


az rest --method post --url "https://management.azure.com/providers/Microsoft.Authorization/elevateAccess?api-version=2016-07-01"